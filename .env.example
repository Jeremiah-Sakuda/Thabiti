# ─────────────────────────────────────────────────────────────────────────────
# Thabiti configuration. Copy to `.env.local` for Next.js, or `.env` for scripts.
# The whole product runs locally with ZERO cloud deps on THABITI_BACKEND=memory.
# ─────────────────────────────────────────────────────────────────────────────

# Engine selection: "memory" (zero cloud deps) or "aurora" (real DB).
THABITI_BACKEND=memory

# Allowed-lateness bound. Watermark = max(event_time seen) − this grace.
# Events later than this against a sealed window are quarantined.
THABITI_LATENESS_GRACE_MS=2000

# Optional durable write-ahead log for the memory backend. When set, the
# append-only log is mirrored to this JSONL file so the in-memory engine
# survives a process crash and replays to a bit-identical total on restart.
# THABITI_MEMORY_WAL=.thabiti-runtime/event-log.wal.jsonl

# ── Aurora PostgreSQL Serverless v2 (only used when THABITI_BACKEND=aurora) ──
# Writer endpoint — append-only ingest hammers this. Route through RDS Proxy.
AURORA_WRITER_URL=postgresql://thabiti:PASSWORD@your-proxy.proxy-xxxx.us-east-1.rds.amazonaws.com:5432/thabiti?sslmode=require
# Optimized-Reads reader endpoint — the heavy window-function aggregation runs
# here, isolated from write pressure. Route through the RDS Proxy read endpoint.
AURORA_READER_URL=postgresql://thabiti:PASSWORD@your-proxy-read-only.endpoint.proxy-xxxx.us-east-1.rds.amazonaws.com:5432/thabiti?sslmode=require

# ── CloudWatch (live ACU graphs + cost-per-run readout) ──
AWS_REGION=us-east-1
# DBClusterIdentifier of the Aurora Serverless v2 cluster.
AURORA_CLUSTER_ID=thabiti-cluster
# Published Aurora Serverless v2 price per ACU-hour (us-east-1). Adjust to the
# current public figure at demo time; used to compute cost-per-run on screen.
AURORA_ACU_HOUR_USD=0.12
# Standard AWS credential env vars are read by the SDK if present:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
